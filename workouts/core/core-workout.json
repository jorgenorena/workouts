          "description": "Opposite arm-leg extension."
        },

        {
          "name": "Side plank (left)",
          "mode": "time",
          "duration_sec": 35,
          "description": "Straight body line."
        },

        {
          "name": "Side plank (right)",
          "mode": "time",
          "duration_sec": 35,
          "description": "Control breathing."
        },

        {
          "name": "Glute bridge",
          "mode": "reps",
          "repetitions": 12,
          "wait_for_user": true,
          "description": "Drive through heels."
        },

        {
          "name": "Bird dog",
          "mode": "reps",
          "repetitions": 10,
          "wait_for_user": true,
          "description": "Pause briefly."
        }

      ]
    },

    {
      "name": "Final stretching",
      "type": "sequence",
      "exercises": [

        {
          "name": "Hip flexor stretch (left)",
          "mode": "time",
          "duration_sec": 30,
