        },

        {
          "name": "Hip flexor stretch (right)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Relax shoulders."
        },

        {
          "name": "Figure-4 glute stretch (left)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Gentle pull."
        },

        {
          "name": "Figure-4 glute stretch (right)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Slow breathing."
        },

        {
          "name": "Side body stretch (left)",
          "mode": "time",
          "duration_sec": 25,
          "description": "Reach upward."
        },

        {
          "name": "Side body stretch (right)",
          "mode": "time",
          "duration_sec": 25,
          "description": "Expand ribs."
        },

        {
          "name": "Child pose",
          "mode": "time",
          "duration_sec": 40,
          "description": "Relax trunk."
        },

        {
          "name": "Supine spinal twist (left)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Release abdomen."
        },

        {
          "name": "Supine spinal twist (right)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Heavy shoulders."
        }

      ]
