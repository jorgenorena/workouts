    },

    {
      "name": "Final stretching",
      "type": "sequence",
      "exercises": [

        {
          "name": "Hip flexor stretch (left)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Posterior tilt."
        },

        {
          "name": "Hip flexor stretch (right)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Relax neck."
        },

        {
          "name": "Figure-4 stretch (left)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Gentle pull."
        },

        {
          "name": "Figure-4 stretch (right)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Slow breathing."
        },

        {
          "name": "Child pose",
          "mode": "time",
          "duration_sec": 40,
          "description": "Let trunk relax."
        },

        {
          "name": "Supine twist (left)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Release core."
        },

        {
          "name": "Supine twist (right)",
          "mode": "time",
          "duration_sec": 30,
          "description": "Heavy shoulders."
        }

      ]
