{
  "name": "Core + Light Calisthenics V2",
  "total_rounds": 1,
  "sound": true,
  "keep_screen_on": true,

  "sections": [

    {
      "name": "Warmup",
      "type": "sequence",
      "exercises": [

        {
          "name": "Marching in place with arm swing",
          "mode": "time",
          "duration_sec": 70,
          "description": "Increase rhythm gradually."
        },

        {
          "name": "Hip circles + weight shift",
          "mode": "time",
          "duration_sec": 50,
          "description": "Feel balance from one leg to the other."
        },

        {
          "name": "Deep bodyweight squats (warmup)",
          "mode": "reps",
          "repetitions": 14,
          "wait_for_user": true,
          "description": "Pause briefly at bottom."
        },

        {
          "name": "Thoracic rotations",
          "mode": "time",
          "duration_sec": 45,
          "description": "Rotate gently. Keep hips stable."
        }

      ]
    },

    {
      "name": "Light calisthenics",
      "type": "circuit",
      "rounds": 3,
      "rest_between_exercises_sec": 30,
      "rest_between_rounds_sec": 75,

      "exercises": [

        {
          "name": "Bodyweight squats",
          "mode": "reps",
          "repetitions": 18,
          "wait_for_user": true,
          "description": "Controlled descent (3 sec)."
        },

        {
          "name": "Split squat (left)",
          "mode": "reps",
          "repetitions": 10,
          "wait_for_user": true,
          "description": "Front knee tracks forward."
        },

        {
          "name": "Split squat (right)",
          "mode": "reps",
          "repetitions": 10,
          "wait_for_user": true,
          "description": "Stay upright."
        },

        {
          "name": "Band rows",
          "mode": "reps",
          "repetitions": 14,
          "wait_for_user": true,
          "description": "Slow return phase."
        }

      ]
    },

    {
      "name": "Core block",
