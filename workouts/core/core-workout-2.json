        },

        {
          "name": "Bird dog",
          "mode": "reps",
          "repetitions": 12,
          "wait_for_user": true,
          "description": "Pause at full reach."
        },

        {
          "name": "Frontal plank",
          "mode": "time",
          "duration_sec": 45,
          "description": "Brace harder than V1."
